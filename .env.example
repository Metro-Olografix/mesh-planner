# Copy to .env and fill in the values

# PostgreSQL
POSTGRES_PASSWORD=change_me_in_production

# OIDC — works with any OIDC-compliant provider (Zitadel, Keycloak, Auth0, Okta…)
# Injected into the frontend at runtime — no build args needed.
OIDC_ISSUER=https://auth.example.com       # no trailing slash
OIDC_CLIENT_ID=your_oidc_client_id
OIDC_AUDIENCE=                             # optional: enforce aud claim (leave empty for Zitadel)

# Set to true to allow unauthenticated read-only access (coordinates fuzzed, PII hidden)
PUBLIC_ACCESS=false

# Logging: DEBUG | INFO | WARNING | ERROR (default: INFO)
LOG_LEVEL=INFO
