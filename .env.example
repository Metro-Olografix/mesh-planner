# Copy to .env and fill in the values

# PostgreSQL
POSTGRES_PASSWORD=change_me_in_production

# Zitadel OIDC
ZITADEL_DOMAIN=https://auth.olografix.org  # no trailing slash
ZITADEL_CLIENT_ID=your_zitadel_client_id

# Logging: DEBUG | INFO | WARNING | ERROR (default: INFO)
LOG_LEVEL=INFO

# Frontend — baked into the JS bundle at build time by Vite.
# These are read by docker-compose and passed as build args to the Dockerfile.
VITE_ZITADEL_AUTHORITY=https://auth.olografix.org
VITE_ZITADEL_CLIENT_ID=your_zitadel_client_id
